            "kind": "Deployment",
            "live_manifest_incluster": "0446cb45004793f46facae9d16d4db35c5256fae02389f8adc4b8d5010cb6452",
            "live_uid": "11bcb221-3580-4353-b8c7-63a696810ce7",
            "name": "web",
            "namespace": "app-space",
            "override_namespace": null,
            "sensitive_fields": null,
            "server_side_apply": false,
            "timeouts": null,
            "uid": "11bcb221-3580-4353-b8c7-63a696810ce7",
            "validate_schema": true,
            "wait": null,
            "wait_for_rollout": true,
            "yaml_body": "apiVersion: apps/v1\r\nkind: Deployment\r\nmetadata:\r\n  name: web\r\n  namespace: app-space\r\nspec:\r\n  replicas: 1\r\n  selector:\r\n    matchLabels:\r\n      app: web\r\n      version: v1\r\n  template:\r\n    metadata:\r\n      labels:\r\n        app: web\r\n        version: v1\r\n    spec:\r\n      containers:\r\n        # ===============================\r\n        # NGINX FRONT PROXY (SIDE CAR)\r\n        # ===============================\r\n        - name: web-nginx\r\n          image: nginx:1.21.6\r\n          ports:\r\n            - containerPort: 8080\r\n          resources:\r\n            requests:\r\n              cpu: \"50m\"\r\n              memory: \"50Mi\"\r\n            limits:\r\n              cpu: \"100m\"\r\n              memory: \"100Mi\"\r\n          volumeMounts:\r\n            - name: nginx-config\r\n              mountPath: /etc/nginx/conf.d\r\n\r\n\r\n        # ===============================\r\n        # EXISTING WEB CONTAINER\r\n        # ===============================\r\n        - name: robot-app-web\r\n          image: 038774803581.dkr.ecr.eu-west-2.amazonaws.com/web:v1\r\n          imagePullPolicy: Always\r\n          ports:\r\n            - containerPort: 3000\r\n          env:\r\n            - name: SESSION_SECURE\r\n              value: \"false\"\r\n            - name: SESSION_SAMESITE\r\n              value: \"lax\"\r\n            - name: INSTANA_DISABLE_AUTO_INSTR\r\n              value: \"true\"\r\n          resources:\r\n            requests:\r\n              cpu: \"100m\"\r\n              memory: \"60Mi\"\r\n            limits:\r\n              cpu: \"200m\"\r\n              memory: \"100Mi\"\r\n\r\n      volumes:\r\n        - name: nginx-config\r\n          configMap:\r\n            name: web-nginx-config\r\n",
            "yaml_body_parsed": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: web\n  namespace: app-space\nspec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app: web\n      version: v1\n  template:\n    metadata:\n      labels:\n        app: web\n        version: v1\n    spec:\n      containers:\n      - image: nginx:1.21.6\n        name: web-nginx\n        ports:\n        - containerPort: 8080\n        resources:\n          limits:\n            cpu: 100m\n            memory: 100Mi\n          requests:\n            cpu: 50m\n            memory: 50Mi\n        volumeMounts:\n        - mountPath: /etc/nginx/conf.d\n          name: nginx-config\n      - env:\n        - name: SESSION_SECURE\n          value: \"false\"\n        - name: SESSION_SAMESITE\n          value: lax\n        - name: INSTANA_DISABLE_AUTO_INSTR\n          value: \"true\"\n        image: 038774803581.dkr.ecr.eu-west-2.amazonaws.com/web:v1\n        imagePullPolicy: Always\n        name: robot-app-web\n        ports:\n        - containerPort: 3000\n        resources:\n          limits:\n            cpu: 200m\n            memory: 100Mi\n          requests:\n            cpu: 100m\n            memory: 60Mi\n      volumes:\n      - configMap:\n          name: web-nginx-config\n        name: nginx-config\n",
            "yaml_incluster": "0446cb45004793f46facae9d16d4db35c5256fae02389f8adc4b8d5010cb6452"
