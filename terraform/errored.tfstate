            "wait": null,
            "wait_for_rollout": true,
            "yaml_body": "apiVersion: apps/v1\r\nkind: Deployment\r\nmetadata:\r\n  name: rabbitmq\r\n  namespace: data-space\r\nspec:\r\n  replicas: 1\r\n  selector:\r\n    matchLabels:\r\n      app: rabbitmq\r\n  template:\r\n    metadata:\r\n      labels:\r\n        app: rabbitmq\r\n    spec:\r\n      containers:\r\n      - name: rabbitmq\r\n        image: rabbitmq:3.8-management-alpine\r\n        ports:\r\n        - containerPort: 5672\r\n        env:\r\n          - name: RABBITMQ_DEFAULT_USER\r\n            value: guest\r\n          - name: RABBITMQ_DEFAULT_PASS\r\n            value: guest\r\n          - name: RABBITMQ_ALLOW_GUEST\r\n            value: \"true\"\r\n        resources:\r\n          requests:\r\n            cpu: \"100m\"\r\n            memory: \"128Mi\"\r\n          limits:\r\n            cpu: \"500m\"\r\n            memory: \"256Mi\"\r\n",
            "yaml_body_parsed": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: rabbitmq\n  namespace: data-space\nspec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app: rabbitmq\n  template:\n    metadata:\n      labels:\n        app: rabbitmq\n    spec:\n      containers:\n      - env:\n        - name: RABBITMQ_DEFAULT_USER\n          value: guest\n        - name: RABBITMQ_DEFAULT_PASS\n          value: guest\n        - name: RABBITMQ_ALLOW_GUEST\n          value: \"true\"\n        image: rabbitmq:3.8-management-alpine\n        name: rabbitmq\n        ports:\n        - containerPort: 5672\n        resources:\n          limits:\n            cpu: 500m\n            memory: 256Mi\n          requests:\n            cpu: 100m\n            memory: 128Mi\n",
